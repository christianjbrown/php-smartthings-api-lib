{
    "name": "christianjbrown/smarthings-api",
    "require": {
        "php": "^8.2",
        "christianjbrown/user-friendly-exception": "dev-main",
        "christianjbrown/json-api-client": "dev-main",
        "psr/http-client": "^1.0"
    },
    "minimum-stability": "dev",
    "scripts": {
        "test": [
            "./vendor/bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "lint": [
            "./vendor/bin/phpcs --standard=vendor/christianjbrown/phpcs-tools/standards/ChristianBrown ./src ./tests || true"
        ],
        "fix": [
            "./vendor/bin/php-cs-fixer fix ./src ./tests -vvv --config=vendor/christianjbrown/php-cs-fixer-wrapper/rule-sets/risky.php"
        ],
        "fix-lint-test": [
            "@fix",
            "@lint",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\SmartThings\\": "src/",
            "ChristianBrown\\SmartThings\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/user-friendly-exception.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/json-api-client.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/phpcs-tools.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-cs-fixer-wrapper.git"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0@dev",
        "christianjbrown/php-cs-fixer-wrapper": "dev-main",
        "ext-xdebug": "*"
    }
}
