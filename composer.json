{
    "name": "christianjbrown/php-smartthings-api-lib",
    "description": "A strongly-typed, read-only PHP 8.3+ client for the SmartThings API that returns typed model objects instead of raw arrays.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "smartthings",
        "api",
        "client",
        "iot",
        "home-automation"
    ],
    "authors": [
        {
            "name": "Christian Brown"
        }
    ],
    "require": {
        "php": "^8.3",
        "christianjbrown/php-api-client-lib": "dev-main",
        "psr/container": "^2.0",
        "symfony/dependency-injection": "^7.2"
    },
    "require-dev": {
        "christianjbrown/php-code-quality-scripts": "dev-main",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.0"
    },
    "config": {
        "bin-dir": "bin"
    },
    "scripts": {
        "test": [
            "clear && XDEBUG_MODE=coverage php -d memory_limit=-1 ./bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "check-style": [
            "clear && ./bin/php-cs ./src ./tests"
        ],
        "check-style-diff": [
            "clear && ./bin/php-cs-diff"
        ],
        "fix-style": [
            "clear && ./bin/php-cs-fix ./src ./tests"
        ],
        "fix-style-diff": [
            "clear && ./bin/php-cs-fix-diff"
        ],
        "stan": [
            "clear && ./bin/phpstan analyse"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\SmartThings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChristianBrown\\SmartThings\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-code-quality-scripts.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-api-client-lib.git"
        }
    ],
    "minimum-stability": "dev"
}
